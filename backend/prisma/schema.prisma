// prisma/schema.prisma
// Gutoria Dairies – multi-tenant data model
// Every tenant-scoped table has dairyId
// Gutoria Dairies = dairyId 1 (seeded, zero-downtime migration)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PaymentMethod {
  MPESA
  BANK
}

enum EmployeeRole {
  GRADER
  DRIVER
  SHOPKEEPER
  FACTORY
  OFFICE
  ADMIN
  SUPER_ADMIN   // new: platform-level admin across all dairies
}

enum PayrollStatus {
  PENDING
  APPROVED
  PAID
}

enum VarianceType {
  GRADER_COLLECTION
  DRIVER_DELIVERY
  SHOP_REMITTANCE
}

enum DairyPlan {
  TRIAL       // 14-day free trial
  SMALL       // up to 200 farmers
  MEDIUM      // up to 1000 farmers
  LARGE       // unlimited farmers
}

enum DairyStatus {
  TRIAL
  ACTIVE
  SUSPENDED   // payment overdue
  CANCELLED
}

// ─── Dairy (tenant) ────────────────────────────────────────────────────────────
// One row per dairy company using the platform

model Dairy {
  id              Int         @id @default(autoincrement())
  name            String      // e.g. "Gutoria Dairies"
  slug            String      @unique  // e.g. "gutoria" — used in URLs
  phone           String?
  email           String?
  location        String?
  logoUrl         String?
  plan            DairyPlan   @default(TRIAL)
  status          DairyStatus @default(TRIAL)
  maxFarmers      Int         @default(200)
  trialEndsAt     DateTime?
  subscriptionEndsAt DateTime?
  monthlyFee      Decimal     @default(0)
  // KopoKopo per-dairy credentials
  kopokopoClientId     String?
  kopokopoClientSecret String?
  kopokopoTillId       String?
  kopokopoEnv          String  @default("sandbox")
  // Africa's Talking per-dairy SMS
  atApiKey        String?
  atUsername      String?
  atSenderId      String      @default("DAIRY")
  // Manager contact for variance alerts
  managerPhone    String?

  routes          Route[]
  farmers         Farmer[]
  employees       Employee[]
  collections     MilkCollection[]
  advances        FarmerAdvance[]
  deductions      FarmerDeduction[]
  payments        FarmerPayment[]
  payrolls        Payroll[]
  shops           Shop[]
  factoryReceipts FactoryReceipt[]
  batches         PasteurizationBatch[]
  deliveries      DeliveryToShop[]
  shopSales       ShopSale[]
  shopDrops       ShopDrop[]
  driverTrips     DriverTrip[]
  liquidRecords   LiquidRecord[]
  litresEntries   LitresEntry[]
  litresBalances  LitresBalance[]
  varianceRecords VarianceRecord[]
  configs         SystemConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Route ────────────────────────────────────────────────────────────────────

model Route {
  id           Int  @id @default(autoincrement())
  dairyId      Int
  code         String
  name         String
  supervisorId Int?

  dairy         Dairy            @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  supervisor    Employee?        @relation("RouteSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  farmers       Farmer[]
  collections   MilkCollection[]
  liquidRecords LiquidRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, code])   // code unique per dairy, not globally
}

// ─── Farmer ───────────────────────────────────────────────────────────────────

model Farmer {
  id            Int           @id @default(autoincrement())
  dairyId       Int
  code          String
  name          String
  idNumber      String?
  phone         String
  routeId       Int
  pricePerLitre Decimal
  paymentMethod PaymentMethod @default(MPESA)
  mpesaPhone    String?
  bankName      String?
  bankAccount   String?
  paidOn15th    Boolean       @default(false)
  isActive      Boolean       @default(true)

  dairy       Dairy            @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  route       Route            @relation(fields: [routeId], references: [id])
  collections MilkCollection[]
  advances    FarmerAdvance[]
  deductions  FarmerDeduction[]
  payments    FarmerPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, code])   // code unique per dairy
}

// ─── Employee ─────────────────────────────────────────────────────────────────

model Employee {
  id            Int           @id @default(autoincrement())
  dairyId       Int
  code          String
  name          String
  phone         String
  role          EmployeeRole
  salary        Decimal
  paymentMethod PaymentMethod @default(MPESA)
  mpesaPhone    String?
  bankName      String?
  bankAccount   String?
  isActive      Boolean       @default(true)
  passwordHash  String?

  dairy            Dairy          @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  supervisedRoutes Route[]        @relation("RouteSupervisor")
  managedShop      Shop?          @relation("ShopKeeper")
  collections      MilkCollection[]
  factoryReceipts  FactoryReceipt[]
  deliveries       DeliveryToShop[]
  varianceRecords  VarianceRecord[]
  payrolls         Payroll[]
  driverTrips      DriverTrip[]
  liquidRecords    LiquidRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, code])
}

// ─── Milk Collection ──────────────────────────────────────────────────────────

model MilkCollection {
  id          Int      @id @default(autoincrement())
  dairyId     Int
  farmerId    Int
  routeId     Int
  graderId    Int
  litres      Decimal
  collectedAt DateTime
  synced      Boolean  @default(false)
  smsSent     Boolean  @default(false)
  receiptNo   String?

  dairy  Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  farmer Farmer   @relation(fields: [farmerId], references: [id])
  route  Route    @relation(fields: [routeId], references: [id])
  grader Employee @relation(fields: [graderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dairyId, collectedAt])
  @@index([dairyId, farmerId, collectedAt])
  @@index([dairyId, routeId, collectedAt])
}

// ─── Factory ──────────────────────────────────────────────────────────────────

model FactoryReceipt {
  id         Int      @id @default(autoincrement())
  dairyId    Int
  graderId   Int
  litres     Decimal
  receivedAt DateTime
  notes      String?

  dairy   Dairy                 @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  grader  Employee              @relation(fields: [graderId], references: [id])
  batches PasteurizationBatch[] @relation("BatchReceipts")

  createdAt DateTime @default(now())
}

model PasteurizationBatch {
  id           Int      @id @default(autoincrement())
  dairyId      Int
  batchNo      String
  inputLitres  Decimal
  outputLitres Decimal
  lossLitres   Decimal  @default(0)
  processedAt  DateTime
  qualityNotes String?

  dairy      Dairy           @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  receipts   FactoryReceipt[] @relation("BatchReceipts")
  deliveries DeliveryToShop[]

  createdAt DateTime @default(now())

  @@unique([dairyId, batchNo])
}

// ─── Shop & Sales ─────────────────────────────────────────────────────────────

model Shop {
  id         Int     @id @default(autoincrement())
  dairyId    Int
  code       String
  name       String
  location   String?
  keeperId   Int     @unique
  tillNumber String?

  dairy        Dairy                 @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  keeper       Employee              @relation("ShopKeeper", fields: [keeperId], references: [id])
  deliveries   DeliveryToShop[]
  sales        ShopSale[]
  kopokopoTxns KopokopoTransaction[]
  shopDrops    ShopDrop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, code])
}

model DeliveryToShop {
  id           Int      @id @default(autoincrement())
  dairyId      Int
  batchId      Int
  shopId       Int
  driverId     Int
  litres       Decimal
  sellingPrice Decimal
  deliveredAt  DateTime

  dairy  Dairy               @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  batch  PasteurizationBatch @relation(fields: [batchId], references: [id])
  shop   Shop                @relation(fields: [shopId], references: [id])
  driver Employee            @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())
}

model ShopSale {
  id              Int      @id @default(autoincrement())
  dairyId         Int
  shopId          Int
  saleDate        DateTime
  litresSold      Decimal
  expectedRevenue Decimal
  cashCollected   Decimal
  tillAmount      Decimal  @default(0)
  variance        Decimal  @default(0)
  reconciled      Boolean  @default(false)

  dairy Dairy @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  shop  Shop  @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model FarmerAdvance {
  id          Int      @id @default(autoincrement())
  dairyId     Int
  farmerId    Int
  amount      Decimal
  advanceDate DateTime
  notes       String?

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  farmer    Farmer   @relation(fields: [farmerId], references: [id])
  createdAt DateTime @default(now())
}

model FarmerDeduction {
  id            Int      @id @default(autoincrement())
  dairyId       Int
  farmerId      Int
  amount        Decimal
  reason        String
  deductionDate DateTime
  periodMonth   Int
  periodYear    Int

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  farmer    Farmer   @relation(fields: [farmerId], references: [id])
  createdAt DateTime @default(now())
}

model FarmerPayment {
  id              Int           @id @default(autoincrement())
  dairyId         Int
  farmerId        Int
  periodMonth     Int
  periodYear      Int
  isMidMonth      Boolean       @default(false)
  grossPay        Decimal
  totalAdvances   Decimal
  totalDeductions Decimal
  netPay          Decimal
  status          PayrollStatus @default(PENDING)
  kopokopoRef     String?
  paidAt          DateTime?

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  farmer    Farmer   @relation(fields: [farmerId], references: [id])
  createdAt DateTime @default(now())

  @@unique([dairyId, farmerId, periodMonth, periodYear, isMidMonth])
}

// ─── Staff Payroll ────────────────────────────────────────────────────────────

model Payroll {
  id                 Int           @id @default(autoincrement())
  dairyId            Int
  employeeId         Int
  periodMonth        Int
  periodYear         Int
  baseSalary         Decimal
  varianceDeductions Decimal       @default(0)
  otherDeductions    Decimal       @default(0)
  netPay             Decimal
  status             PayrollStatus @default(PENDING)
  kopokopoRef        String?
  paidAt             DateTime?

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  employee  Employee @relation(fields: [employeeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([dairyId, employeeId, periodMonth, periodYear])
}

model VarianceRecord {
  id          Int          @id @default(autoincrement())
  dairyId     Int
  employeeId  Int
  type        VarianceType
  amount      Decimal
  recordDate  DateTime
  periodMonth Int
  periodYear  Int
  description String?
  applied     Boolean      @default(false)

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  employee  Employee @relation(fields: [employeeId], references: [id])
  createdAt DateTime @default(now())
}

// ─── Kopokopo ─────────────────────────────────────────────────────────────────

model KopokopoTransaction {
  id              Int      @id @default(autoincrement())
  shopId          Int
  tillNumber      String
  amount          Decimal
  transactionRef  String   @unique
  transactionDate DateTime
  matched         Boolean  @default(false)

  shop      Shop     @relation(fields: [shopId], references: [id])
  createdAt DateTime @default(now())
}

// ─── Driver Trip ──────────────────────────────────────────────────────────────

model DriverTrip {
  id            Int      @id @default(autoincrement())
  dairyId       Int
  driverId      Int
  tripDate      DateTime
  routesCovered String?
  totalLitres   Decimal  @default(0)
  status        String   @default("PENDING")
  notes         String?

  dairy     Dairy           @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  driver    Employee        @relation(fields: [driverId], references: [id])
  shopDrops ShopDrop[]
  expenses  DriverExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopDrop {
  id        Int      @id @default(autoincrement())
  dairyId   Int
  tripId    Int
  shopId    Int
  litres    Decimal  @default(0)
  droppedAt DateTime

  dairy Dairy      @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  trip  DriverTrip @relation(fields: [tripId], references: [id])
  shop  Shop       @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())
}

model DriverExpense {
  id          Int      @id @default(autoincrement())
  tripId      Int
  description String
  amount      Decimal  @default(0)
  expenseDate DateTime

  trip DriverTrip @relation(fields: [tripId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Liquid Ledger ────────────────────────────────────────────────────────────

model LiquidRecord {
  id         Int      @id @default(autoincrement())
  dairyId    Int
  routeId    Int
  graderId   Int?
  recordDate DateTime
  received   Decimal  @default(0)
  dispatched Decimal  @default(0)
  variance   Decimal  @default(0)
  notes      String?

  dairy  Dairy     @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  route  Route     @relation(fields: [routeId], references: [id])
  grader Employee? @relation(fields: [graderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, routeId, recordDate])
}

// ─── Litres Ledger ────────────────────────────────────────────────────────────

model LitresEntry {
  id      Int     @id @default(autoincrement())
  dairyId Int
  section String
  name    String
  day     Int
  month   Int
  year    Int
  value   Decimal @default(0)

  dairy     Dairy    @relation(fields: [dairyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dairyId, section, name, day, month, year])
}

model LitresBalance {
  id      Int     @id @default(autoincrement())
  dairyId Int
  day     Int
  month   Int
  year    Int
  balance Decimal @default(0)

  dairy Dairy @relation(fields: [dairyId], references: [id], onDelete: Cascade)

  @@unique([dairyId, day, month, year])
}

// ─── System Config (per dairy) ────────────────────────────────────────────────

model SystemConfig {
  id        Int      @id @default(autoincrement())
  dairyId   Int
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  dairy Dairy @relation(fields: [dairyId], references: [id], onDelete: Cascade)

  @@unique([dairyId, key])
}
